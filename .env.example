# === LLM Provider ===
OPENROUTER_API_KEY=your_openrouter_api_key_here

# === Dropbox Integration ===
DROPBOX_REFRESH_TOKEN=your_dropbox_refresh_token
DROPBOX_APP_KEY=your_dropbox_app_key
DROPBOX_APP_SECRET=your_dropbox_app_secret

# === Airtable Integration (for email-airtable source) ===
AIRTABLE_API_KEY=your_airtable_api_key
AIRTABLE_BASE_ID=your_airtable_base_id
AIRTABLE_EMAIL_TABLE_ID=your_airtable_table_id

# === IMAP Email ===
# Primary account
IMAP_USERNAME=your_imap_username
IMAP_PASSWORD=your_imap_password
# Additional accounts (reference in config.yaml)
# IMAP_USERNAME_2=your_second_imap_username
# IMAP_PASSWORD_2=your_second_imap_password
